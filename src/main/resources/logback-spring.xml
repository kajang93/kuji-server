<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console Appender for JSON format -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Include custom fields -->
            <customFields>{"app_name":"kuji-server"}</customFields>
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <includeMdcKeyName>memberId</includeMdcKeyName>
            <includeMdcKeyName>requestUri</includeMdcKeyName>
            <includeMdcKeyName>eventType</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- Console Appender for plain text (useful for local development) -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [%X{requestId}] [%X{memberId}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Business Audit Log (File Appender) -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/audit-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"log_type":"audit"}</customFields>
        </encoder>
    </appender>

    <logger name="com.kuji.backend.audit" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE" />
        <appender-ref ref="CONSOLE_JSON" />
    </logger>

    <!-- Spring Profile: Local uses plain, Prod uses JSON -->
    <springProfile name="local | dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN" />
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON" />
        </root>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE_PLAIN" />
    </root>

</configuration>
